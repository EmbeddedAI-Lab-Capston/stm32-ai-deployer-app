#
# GCC_PATH is set automatically by PipelineRunner.
# CUBE_SDK_PATH must point to the STM32CubeF4 SDK root, e.g.:
#   C:/Users/<user>/STM32Cube/Repository/STM32Cube_FW_F4_V1.28.0
##########################################################################

TARGET = {{MODEL_NAME}}_{{BOARD_NAME}}
BUILD_DIR = build

# Default SDK path — override on command line or set env var
CUBE_SDK_PATH ?= $(HOME)/STM32Cube/Repository/STM32Cube_FW_F4_V1.28.0
X_CUBE_AI_PATH ?=
AI_RUNTIME_LIB ?= $(wildcard $(X_CUBE_AI_PATH)/Lib/GCC/ARMCortexM4/NetworkRuntime*_CM4_GCC.a)

# Toolchain prefix (set via GCC_PATH or must be on PATH)
ifeq ($(GCC_PATH),)
PREFIX = arm-none-eabi-
else
PREFIX = $(GCC_PATH)/arm-none-eabi-
endif

CC  = $(PREFIX)gcc
CXX = $(PREFIX)g++
AS  = $(PREFIX)gcc -x assembler-with-cpp
CP  = $(PREFIX)objcopy
SZ  = $(PREFIX)size

HEX = $(CP) -O ihex
BIN = $(CP) -O binary -S

# MCU
MCU = -mcpu=cortex-m4 -mthumb -mfpu=fpv4-sp-d16 -mfloat-abi=hard

# Optimisation
OPT = -O2

# C sources
C_SOURCES = \
  Src/main.c \
  Src/stm32f4xx_hal_msp.c \
  Src/stm32f4xx_it.c \
  Src/{{SENSOR_TYPE_LOWER}}.c \
  Src/ai_runner.c \
  Src/uart_report.c \
  Src/network.c \
  Src/network_data.c \
  Src/network_data_params.c \
  $(CUBE_SDK_PATH)/Drivers/CMSIS/Device/ST/STM32F4xx/Source/Templates/system_stm32f4xx.c \
  $(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal.c \
  $(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_cortex.c \
  $(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_gpio.c \
  $(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_rcc.c \
  $(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_rcc_ex.c \
  $(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_uart.c \
  $(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_dma.c \
  $(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2c.c \
  $(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_tim.c \
  $(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_pwr.c \
  $(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_pwr_ex.c

# ASM sources
ASM_SOURCES = startup_stm32f407xx.s

# C includes
C_INCLUDES = \
  -IInc \
  -I$(X_CUBE_AI_PATH)/Inc \
  -I$(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Inc \
  -I$(CUBE_SDK_PATH)/Drivers/STM32F4xx_HAL_Driver/Inc/Legacy \
  -I$(CUBE_SDK_PATH)/Drivers/CMSIS/Device/ST/STM32F4xx/Include \
  -I$(CUBE_SDK_PATH)/Drivers/CMSIS/Include

# Defines
C_DEFS = -DUSE_HAL_DRIVER -DSTM32F407xx

# Flags
CFLAGS  = $(MCU) $(C_DEFS) $(C_INCLUDES) $(OPT) -Wall -fdata-sections -ffunction-sections -g -gdwarf-2
ASFLAGS = $(MCU) $(OPT) -Wall -fdata-sections -ffunction-sections -g -gdwarf-2
LDFLAGS = $(MCU) -specs=nano.specs -specs=nosys.specs -TSTM32F407VGTx_FLASH.ld \
          -Wl,-Map=$(BUILD_DIR)/$(TARGET).map,--cref -Wl,--gc-sections

all: $(BUILD_DIR)/$(TARGET).elf $(BUILD_DIR)/$(TARGET).hex
	@echo "Build complete: $(TARGET)"

OBJECTS  = $(addprefix $(BUILD_DIR)/,$(notdir $(C_SOURCES:.c=.o)))
vpath %.c $(sort $(dir $(C_SOURCES)))
OBJECTS += $(addprefix $(BUILD_DIR)/,$(notdir $(ASM_SOURCES:.s=.o)))
vpath %.s $(sort $(dir $(ASM_SOURCES)))

$(BUILD_DIR)/%.o: %.c Makefile | $(BUILD_DIR)
	$(CC) -c $(CFLAGS) -Wa,-a,-ad,-alms=$(BUILD_DIR)/$(notdir $(<:.c=.lst)) $< -o $@

$(BUILD_DIR)/%.o: %.s Makefile | $(BUILD_DIR)
	$(AS) -c $(ASFLAGS) $< -o $@

$(BUILD_DIR)/$(TARGET).elf: $(OBJECTS) Makefile
	$(CC) $(OBJECTS) $(AI_RUNTIME_LIB) $(LDFLAGS) -o $@
	$(SZ) $@

$(BUILD_DIR)/%.hex: $(BUILD_DIR)/%.elf | $(BUILD_DIR)
	$(HEX) $< $@

$(BUILD_DIR):
	mkdir -p $@

clean:
	-rm -fR $(BUILD_DIR)

.PHONY: all clean
