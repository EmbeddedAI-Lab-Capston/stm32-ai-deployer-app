##########################################################################
# STM32H7 Makefile — generated by STM32 AI Deployer
# Project : {{MODEL_NAME}} on {{BOARD_NAME}}
#
# Usage:
#   make GCC_PATH=/path/to/gcc/bin CUBE_SDK_PATH=/path/to/STM32CubeH7 all
##########################################################################

TARGET = {{MODEL_NAME}}_{{BOARD_NAME}}
BUILD_DIR = build

CUBE_SDK_PATH ?= $(HOME)/STM32Cube/Repository/STM32Cube_FW_H7_V1.11.2
X_CUBE_AI_PATH ?=
AI_RUNTIME_LIB ?= $(wildcard $(X_CUBE_AI_PATH)/Lib/GCC/ARMCortexM7/NetworkRuntime*_CM7_GCC.a)

ifeq ($(GCC_PATH),)
PREFIX = arm-none-eabi-
else
PREFIX = $(GCC_PATH)/arm-none-eabi-
endif

CC  = $(PREFIX)gcc
AS  = $(PREFIX)gcc -x assembler-with-cpp
CP  = $(PREFIX)objcopy
SZ  = $(PREFIX)size
HEX = $(CP) -O ihex

# Cortex-M7 with FPU double-precision
MCU = -mcpu=cortex-m7 -mthumb -mfpu=fpv5-d16 -mfloat-abi=hard
OPT = -O2

C_SOURCES = \
  Src/main.c \
  Src/stm32h7xx_hal_msp.c \
  Src/stm32h7xx_it.c \
  Src/{{SENSOR_TYPE_LOWER}}.c \
  Src/ai_runner.c \
  Src/uart_report.c \
  Src/network.c \
  Src/network_data.c \
  Src/network_data_params.c \
  $(CUBE_SDK_PATH)/Drivers/CMSIS/Device/ST/STM32H7xx/Source/Templates/system_stm32h7xx.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_cortex.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_gpio.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_rcc.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_rcc_ex.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart_ex.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_dma.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_i2c.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_i2c_ex.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_pwr.c \
  $(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_pwr_ex.c

ASM_SOURCES = startup_stm32h723xx.s

C_INCLUDES = \
  -IInc \
  -I$(X_CUBE_AI_PATH)/Inc \
  -I$(CUBE_SDK_PATH)/Drivers/STM32H7xx_HAL_Driver/Inc \
  -I$(CUBE_SDK_PATH)/Drivers/CMSIS/Device/ST/STM32H7xx/Include \
  -I$(CUBE_SDK_PATH)/Drivers/CMSIS/Include

C_DEFS  = -DUSE_HAL_DRIVER -DSTM32H723xx -DCORE_CM7
CFLAGS  = $(MCU) $(C_DEFS) $(C_INCLUDES) $(OPT) -Wall -fdata-sections -ffunction-sections -g
ASFLAGS = $(MCU) $(OPT) -Wall -fdata-sections -ffunction-sections -g
LDFLAGS = $(MCU) -specs=nano.specs -specs=nosys.specs -TSTM32H723ZGTx_FLASH.ld \
          -Wl,-Map=$(BUILD_DIR)/$(TARGET).map,--cref -Wl,--gc-sections

all: $(BUILD_DIR)/$(TARGET).elf $(BUILD_DIR)/$(TARGET).hex
	@echo "Build complete: $(TARGET)"

OBJECTS  = $(addprefix $(BUILD_DIR)/,$(notdir $(C_SOURCES:.c=.o)))
vpath %.c $(sort $(dir $(C_SOURCES)))
OBJECTS += $(addprefix $(BUILD_DIR)/,$(notdir $(ASM_SOURCES:.s=.o)))
vpath %.s $(sort $(dir $(ASM_SOURCES)))

$(BUILD_DIR)/%.o: %.c Makefile | $(BUILD_DIR)
	$(CC) -c $(CFLAGS) $< -o $@

$(BUILD_DIR)/%.o: %.s Makefile | $(BUILD_DIR)
	$(AS) -c $(ASFLAGS) $< -o $@

$(BUILD_DIR)/$(TARGET).elf: $(OBJECTS) Makefile
	$(CC) $(OBJECTS) $(AI_RUNTIME_LIB) $(LDFLAGS) -o $@
	$(SZ) $@

$(BUILD_DIR)/%.hex: $(BUILD_DIR)/%.elf | $(BUILD_DIR)
	$(HEX) $< $@

$(BUILD_DIR):
	mkdir -p $@

clean:
	-rm -fR $(BUILD_DIR)

.PHONY: all clean
